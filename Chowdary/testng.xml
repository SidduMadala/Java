		</classes>
	</test>

	<test thread-count="5" name="Test">
		<classes>
			<class name="Sahithi.Chowdary.Rama" />
			<class name="Sahithi.Chowdary.Devara" />
			<class name="Sahithi.Chowdary.Dates" />
