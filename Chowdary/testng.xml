		<listener class-name="Sahithi.Chowdary" />
	</listeners>
	<test thread-count="5" name="Test">
		<groups>
			<run>
				<include name="sanity" />
				<exclude name="smoke" />
			</run>
		</groups>
		<classes>
			<class name="Sahithi.Chowdary.Contacts">
